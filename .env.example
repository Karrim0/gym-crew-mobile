# Supabase project URL and anon (public) key.
# Find these in your Supabase project settings > API.
# Never put the service-role key in a NEXT_PUBLIC_ variable or in any
# client-accessible file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public URL used by authentication emails.
# Local: http://localhost:3000
# Production: https://gym-crew-one.vercel.app
NEXT_PUBLIC_APP_URL=

# Server-only key used by Smart Plan Import. Never prefix this with NEXT_PUBLIC.
OPENAI_API_KEY=
# Vision + structured-output model used for plan images, PDFs and spreadsheets.
OPENAI_PLAN_IMPORT_MODEL=gpt-5.6-luna
